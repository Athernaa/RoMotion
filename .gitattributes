# Normalize line endings: store text as LF in the repo, check out natively.
* text=auto eol=lf

# Explicitly treat these as text.
*.luau   text eol=lf
*.lua    text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Binary assets (never touch line endings).
*.png    binary
*.jpg    binary
*.rbxm   binary
*.rbxl   binary
*.rbxmx  binary
*.rbxlx  binary
